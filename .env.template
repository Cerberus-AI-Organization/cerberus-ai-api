# Api Port
PORT=8080

# TLS (Https)
# SSL_CERT_PATH=cert.crt
# SSL_KEY_PATH=cert.key

# Generate Random Secret:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Cors
# set your Web UI Url for better protection (https://localhost)
CORS_URL=*

# Postgres DB Connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=db-name

# Knowledge
# UPDATE_KNOWLEDGE_EVERY how often crawl files and web for new knowledge in hours. If x <= 0 disabled
KNOWLEDGE_UPDATE_INTERVAL=12

# Ollama
# MODEL_KEEPALIVE is in seconds and when -1 model will stay loaded in memory
MODEL_KEEPALIVE=300
# OLLAMA_API_KEY is required for web search functionality
OLLAMA_API_KEY=

# OpenAI-compatible nodes
# OPENAI_EMBED_MODEL is the embedding model for OpenAI nodes (default OpenAi: text-embedding-3-small or vLLM:qwen3-embedding:4b)
OPENAI_EMBED_MODEL=qwen3-embedding:4b

# EMBED_DIM must match the embedding model dimension used across all nodes.
# Default 2560 (qwen3-embedding:4b / Ollama | vLLM). Change and clear ./data/vector_db when switching.
# text-embedding-3-small = 1536, text-embedding-3-large = 3072
EMBED_DIM=2560